	<text>
		<body>
			<pb subtype="einzeln" xml:id="F20_Ms_252_5_1v" facs="#facs_2" n="2"/>
			<pb subtype="durch" xml:id="F20_Ms_252_33v"/>
			<p facs="#facs_2_r1" xml:id="p.NOPo9b" rendition="#nummer">
				<lb facs="#facs_2_r1l1" n="N001"/>26 <link target="Stil_Bd.1_Aufl_I_1860a_s26"/>
			</p>
			<p facs="#facs_2_r2" xml:id="p.UDn2Ss" rendition="#klein">
				<lb facs="#facs_2_r2l1" n="N001"/>Dr<unclear><mod cause="Korrekturdurchgang">i</mod></unclear>ttes Hauptstück.
			</p>
			<p facs="#facs_2_r3" xml:id="p.4JORny" rendition="#corpus_spaced" prev="20_Ms_252_5_1.xml#p.x3FDuV" next="#p.7CWv6r">
				<lb facs="#facs_2_r3l1" n="N001"/>als ein uralter Festschmuck der Architectur, von dem bereits <add place="oberhalb" rend="BrTinte" rendition="#hand" xml:id="add.rE9vRI"><metamark function="Anmerkung" target="#p.iEPslv">&einfüg_2;</metamark></add> <del rend="durchstr Blei_BrTinte" xml:id="del.BOliqD">e</del><add>o</add>ben
				<lb facs="#facs_2_r3l2" n="N002"/>die Rede war, hervorzuheben.
			</p>
			<p facs="#facs_2_r4" xml:id="p.7CWv6r" rendition="#corpus_spaced" prev="#p.4JORny" next="#p.jaPFfj">
				<lb facs="#facs_2_r4l1" n="N001"/>Ueber das Vorkommen dieser architectonisch-ovatorischen Zier-
				<lb facs="#facs_2_r4l2" n="N002" type="hyph"/>den in den verschiedenen Perioden der Kulturgeschichte und <del rend="durchstr Blei_BrTinte" xml:id="del.Eb6LZc"><mod cause="Korrekturdurchgang"><hi rend="unterstr Blei">deren</hi></mod></del> <handShift script="Latein"/><subst><add rend="Blei" rendition="#hand" xml:id="add.yY7alq"><del rend="überschr" xml:id="del.orEjMR">der</del></add><add rend="BrTinte" rendition="#hand" xml:id="add.MqLBaH">der</add></subst><handShift script="Kurrent"/>
				<lb facs="#facs_2_r4l3" n="N003"/>Stilgeschichte werden, dem vorgesteckten Plane gemäss, weiter
				<lb facs="#facs_2_r4l4" n="N004"/>unten einige Notizen folgen.
			</p>
			<p facs="#facs_2_r5" xml:id="p.vd1RuP" rendition="#x-klein">
				<lb facs="#facs_2_r5l1" n="N001"/><metamark function="Einfügung" target="#p.9csxGy"/><del rend="durchstr Blei" xml:id="del.ZQved4">Helmzierden nach griechischen Vasenbildern.</del>
			</p>
			<p facs="#facs_2_r6" xml:id="p.I8tBdj" rendition="#x-klein">
				<lb facs="#facs_2_r6l1" n="N001"/><metamark function="Einfügung" target="#p.mwbF6Z"/><del rend="durchstr Blei" xml:id="del.pxepBF">Griechische Schiffsakroterien.</del>
			</p>
			<p facs="#facs_2_r7" xml:id="p.9Bjnv2" rendition="#x-klein">
				<lb facs="#facs_2_r7l1" n="N001"/><del rend="durchstr Blei" xml:id="del.yUtx3f">Akroterien an Reben und Dächern.</del>
			</p>
			<p facs="#facs_2_r8" xml:id="p.iEPslv" rendition="#hand" rend="STinte">
				<lb facs="#facs_2_r8l1" n="N001"/><subst><add rend="Blei" rendition="#hand" xml:id="add.eaauZA"><del rend="überschr" xml:id="del.lApJzm"><metamark function="Anmerkung">&einfüg_2;</metamark> oben</del></add><add rend="BrTinte" rendition="#hand" xml:id="add.DvMeqM"><metamark function="Anmerkung">&einfüg_2;</metamark> oben</add></subst>
			</p>
			<p facs="#facs_2_r9" xml:id="p.9csxGy" rendition="#hand" rend="Blei" next="#p.njpISE">
				<lb facs="#facs_2_r9l1" n="N001"/><add rend="Blei" rendition="#hand" xml:id="add.IRezje">Gr. und Assyr.</add>
				<lb facs="#facs_2_r9l2" n="N002"/><add rend="Blei" rendition="#hand" xml:id="add.HfQy2i">Helmzierden.</add>
			</p>
			<p facs="#facs_2_r10" xml:id="p.njpISE" rendition="#hand" rend="Blei" prev="#p.9csxGy">
				<lb facs="#facs_2_r10l1" n="N001"/><add rend="Blei" rendition="#hand" xml:id="add.6LgyMC">Ass. Mitra mit</add>
				<lb facs="#facs_2_r10l2" n="N002"/><add rend="Blei" rendition="#hand" xml:id="add.Eas8iY">Federkrone</add>
			</p>
			<p facs="#facs_2_r11" xml:id="p.mwbF6Z" rend="Blei" rendition="#hand">
				<lb facs="#facs_2_r11l1" n="N001"/><add rend="Blei" rendition="#hand" xml:id="add.19650s"><del rend="durchstr Blei" xml:id="del.viWN7C">Akroterien</del> Gr. Akroterien.</add>
			</p>
			<pb subtype="einzeln" xml:id="F20_Ms_252_5_2r"/>
			<pb subtype="durch" xml:id="F20_Ms_252_34r"/> 
			<p facs="#facs_2_r12" xml:id="p.1m3bQ2" rendition="#nummer">
				<lb facs="#facs_2_r12l1" n="N001"/>27 <link target="Stil_Bd.1_Aufl_I_1860a_s27"/>
			</p>
			<p facs="#facs_2_r13" xml:id="p.ahBnvW" rendition="#klein">
				<lb facs="#facs_2_r13l1" n="N001"/><rs type="term" ref="begriffsregister.xml#TERM0005">Textile Kunst</rs>. <add place="nach_Zeile" rend="BrTinte" rendition="#hand" xml:id="add.Cyko1u">Das <rs type="artefact" ref="artefaktenregister.xml#THING0273">Band</rs>.</add>
			</p>
			<p facs="#facs_2_r14" xml:id="p.jaPFfj" rendition="#corpus_spaced" prev="#p.7CWv6r" next="20_Ms_252_5_3.xml#p.8SDam5">
				<lb facs="#facs_2_r14l1" n="N001"/>Sehr nahe verwandt, insofern eine Intention die <hi rendition="#x-space">Richtung</hi>
				<lb facs="#facs_2_r14l2" n="N002"/>des Monumentes zu verdeutlichen bei ihnen hervortritt, sind die
				<lb facs="#facs_2_r14l3" n="N003"/>uralten Dach- und Zinnenaufsätze (Akroterien), die in der <hi rendition="#x-space">Wetter-</hi>
				<lb facs="#facs_2_r14l4" n="N004" type="hyph"/><hi rendition="#x-space">fahne</hi> ihrem technischen Paragon am nächsten kommen. In ihnen
				<lb facs="#facs_2_r14l5" n="N005"/>ist zugleich der Begriff des <hi rendition="#x-space">oberen Abschlusses</hi>, der <hi rendition="#x-space">C<del rend="durchstr Blei" xml:id="del.5si1RL"><hi rend="unterstr OcStift">a</hi></del><metamark function="Einfügung" target="#p.dcsoNp"/>lmi-</hi>
				<lb facs="#facs_2_r14l6" n="N006" type="hyph"/><hi rendition="#x-space">nation</hi> in Verbindung mit dem der <hi rendition="#x-space">Rangauszeichnung</hi> des
				<lb facs="#facs_2_r14l7" n="N007"/>damit geschmückten Gebildes oder Gebildetheiles versinnlicht. In
				<lb facs="#facs_2_r14l8" n="N008"/>diesem Sinne tritt der Federschmuck (Phalos, crista), der seit Ur-
				<lb facs="#facs_2_r14l9" n="N009" type="hyph"/>zeiten die kriegerische Zierde des <hi rendition="#x-space">Häuptlings</hi> bildete und
				<lb facs="#facs_2_r14l10" n="N010"/><add place="vor_Zeile" rend="Blei" rendition="#hand" xml:id="add.othTHR"><handShift script="Latein"/>a<handShift script="Kurrent"/></add><hi rend="unterstr Blei"><del rend="durchstr Blei" xml:id="del.gXxKqX"><seg style="rotateZ(180deg)">a</seg></del>u</hi>ch noch aus der Mitra des assyrischen Herrschers hervorblickt,
				<lb facs="#facs_2_r14l11" n="N011"/>in die Reihe der Begriffsverkettungen; und dieser wieder führt auf
				<lb facs="#facs_2_r14l12" n="N012"/>den Kamm der Hähne und sonstiger kampflustiger Vögel als auf
				<lb facs="#facs_2_r14l13" n="N013"/>das natürliche Vorbild desselben zurück. Ueber sehr ursprüng-
				<lb facs="#facs_2_r14l14" n="N014" type="hyph"/>liche Akroterien und deren Umbildungen im Laufe der Kunstge-
				<lb facs="#facs_2_r14l15" n="N015" type="hyph"/>schichte siehe weiter unten.
			</p>
			<p facs="#facs_2_r15" xml:id="p.dcsoNp" rendition="#hand" rend="Blei">
				<lb facs="#facs_2_r15l1" n="N001"/><add rend="Blei" rendition="#hand" xml:id="add.q0VDzF"><hi rend="unterstr OcStift"><handShift script="Latein"/>u<handShift script="Kurrent"/></hi></add>
			</p>
			<p facs="#facs_2_r16" xml:id="p.PA6sny" rendition="#hand" rend="Blei">
				<lb facs="#facs_2_r16l1" n="N001"/><add rend="Blei" rendition="#hand" xml:id="add.Np55S1">Könnte die oberste</add>
				<lb facs="#facs_2_r16l2" n="N002"/><add rend="Blei" rendition="#hand" xml:id="add.p5g5EM">Figur nicht von der</add>
				<lb facs="#facs_2_r16l3" n="N003"/><add rend="Blei" rendition="#hand" xml:id="add.vQ38Us">untersten abgelöst</add>
				<lb facs="#facs_2_r16l4" n="N004"/><add rend="Blei" rendition="#hand" xml:id="add.BIvAht">werden, so</add>
				<lb facs="#facs_2_r16l5" n="N005"/><add rend="Blei" rendition="#hand" xml:id="add.yTlAHt">dass beide</add>
				<lb facs="#facs_2_r16l6" n="N006"/><add rend="Blei" rendition="#hand" xml:id="add.bfWFkC">aufrecht</add>
				<lb facs="#facs_2_r16l7" n="N007"/><add rend="Blei" rendition="#hand" xml:id="add.sfIAIM">stünden?</add>
				<lb facs="#facs_2_r16l8" n="N008"/><add rend="Blei" rendition="#hand" xml:id="add.9z6olX">(siehe die</add>
				<lb facs="#facs_2_r16l9" n="N009"/><add rend="Blei" rendition="#hand" xml:id="add.m7o20l">Andeutung</add>
				<lb facs="#facs_2_r16l10" n="N010"/><add rend="Blei" rendition="#hand" xml:id="add.8Yh7x6">unten.)</add>
			</p>
			<p facs="#facs_2_r17" xml:id="p.2OIV2t" rendition="#hand" rend="Blei">
				<lb facs="#facs_2_r17l1" n="N001"/><add rend="Blei" rendition="#hand" xml:id="add.cCwXTy">Schiffsakroterien.</add>
			</p>
